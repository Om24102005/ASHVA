# ASHVA — backend environment. Copy to .env and fill REAL values.
# docker compose --env-file .env up -d --build

# ---- Postgres ----
POSTGRES_USER=ashva
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=ashva
POSTGRES_PORT=5432
ADMINER_PORT=8090

# ---- API ----
API_PORT=4000
JWT_SECRET=CHANGE_ME_long_random_string_min_32_chars
JWT_EXPIRES_DAYS=30
OTP_TTL_SEC=300

# ---- MSG91 (SMS + Email OTP) ----
# https://control.msg91.com  (Auth Key, DLT SMS template, verified email domain)
MSG91_AUTHKEY=
MSG91_SENDER_ID=ASHVA
MSG91_SMS_TEMPLATE_ID=
MSG91_EMAIL_FROM=no-reply@yourdomain.com
MSG91_EMAIL_DOMAIN=yourdomain.com
MSG91_EMAIL_TEMPLATE_ID=

# ---- Google Sign-In (server verifies the ID token) ----
# Comma-separated iOS + Android + Web OAuth client IDs.
GOOGLE_CLIENT_IDS=

# ---- MinIO / S3 (KYC document storage) ----
MINIO_ROOT_USER=ashva
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=kyc
S3_REGION=us-east-1
# Public base the phone can reach for viewing KYC images.
# Physical iPhone on your LAN -> your Mac IP, e.g. http://192.168.1.15:9000
S3_PUBLIC_URL=http://localhost:9000
